{
  "name": "abs-rentacar",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/validate-cars.mjs && vite build && node scripts/generate-en-pages.mjs && node scripts/generate-car-pages.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{js,css}\" \"tests/**/*.js\"",
    "validate:data": "node scripts/validate-cars.mjs",
    "test:e2e": "playwright test",
    "fix:lock": "node scripts/fix-lockfile.mjs"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@fontsource/dm-sans": "^5.3.0",
    "@fontsource/epilogue": "^5.3.0",
    "swiper": "^14.0.6"
  },
  "optionalDependencies": {
    "@emnapi/core": "1.11.2",
    "@emnapi/runtime": "1.11.2"
  }
}
